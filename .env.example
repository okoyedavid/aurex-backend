# Application
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
APP_NAME=Aurex
RELEASE=local-development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/aurex

# Authentication
# Replace both values with independent random secrets of at least 32 characters.
JWT_ACCESS_SECRET=replace-with-a-random-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-random-refresh-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# IP geolocation
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# Email (optional outside production)
RESEND_API_KEY=
EMAIL_FROM=Aurex <no-reply@example.com>
# Route all outgoing email to one address during controlled testing.
EMAIL_DELIVERY_OVERRIDE_TO=

# Cloudinary (optional until image uploads are enabled)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paystack
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Use demo with bank code 001 for portfolio/testing; use live in production.
PAYSTACK_VERIFICATION_MODE=demo
PAYSTACK_TEST_BANK_CODE=001

# Employee bank-verification worker
VERIFICATION_WORKER_INTERVAL_MS=1000
VERIFICATION_MAX_ATTEMPTS=5
